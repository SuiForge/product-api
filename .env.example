PRODUCT_API_PORT=8088

PRODUCT_API_SESSION_SECRET=change-me-for-local-dev
PRODUCT_API_SESSION_TTL=24h
PRODUCT_API_SESSION_COOKIE_SECURE=false

PRODUCT_API_PUBLIC_ORIGIN=http://127.0.0.1:8088
PRODUCT_API_SUI_NETWORK=mainnet
PRODUCT_API_WALLET_CHALLENGE_TTL=5m
PRODUCT_API_DATA_FILE=data/product-api-state.json

# Keep this placeholder until you are ready to wire a real Google client:
PRODUCT_API_GOOGLE_CLIENT_ID=
PRODUCT_API_GOOGLE_HOSTED_DOMAIN=

# Built-in product capabilities run in-process by default.
# Legacy upstream envs are no longer required for the main product flow.
